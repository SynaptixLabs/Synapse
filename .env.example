# ============================================================
# SYNAPSE — environment template
# ============================================================
#
# HOW TO USE:  `./start.sh setup` copies this file to `backend/.env` (never overwrites).
# Fill in real values there. NEVER commit an env file with real values —
# .env.example is the ONLY env file that belongs in source control.
#
# Every variable below is actually read by the app (backend/app/core/config.py —
# the one config module). Shell/CI variables override backend/.env.

# ========================
# Model #1 — Distill (node/subtree summarization, Anthropic)
# ========================
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
SUMMARIZER_MODEL=claude-sonnet-5
SUMMARIZER_MAX_TOKENS=4096

# ========================
# Model #2 — Render (summary → image, OpenAI)
# NOTE: gpt-image-1 requires a VERIFIED OpenAI organization.
# ========================
OPENAI_API_KEY=sk-REPLACE-ME
IMAGE_MODEL=gpt-image-1

# ========================
# Zero-cost mode & spend guard
# ========================
# Try the whole distill/render flow WITHOUT keys or cost (deterministic mock providers,
# end-to-end — also what CI and the test suite use):
# SYNAPSE_MOCK_MODELS=1

# Distillations above this ESTIMATED token count ask for confirmation before spending:
# SUMMARIZE_CONFIRM_THRESHOLD=20000

# ========================
# Sources & vault
# ========================
# Comma-separated LOCAL repo paths whose markdown gets indexed.
# This only SEEDS the initial list — after first use, roots are managed in the UI
# (Menu → Sources) and persisted to data/roots.json, which takes precedence.
# With nothing configured, SYNAPSE ingests its own repo (a working demo out of the box).
SYNAPSE_SOURCE_REPOS=/path/to/repo-a,/path/to/repo-b

# Where the vault lives (markdown notes + derived graph.json + Index.md + media/).
# Relative paths resolve against the repo root.
SYNAPSE_VAULT_PATH=./data/vault
