# ============================================================
# SYNAPSE — Environment Variables Master Reference
# ============================================================
#
# HOW TO USE:
#   Development:  copy to .env.development  (or .env for local dev)
#   Staging:      copy to .env.staging
#   Production:   copy to .env.production   (secrets via vault/CI — no values here)
#
# NEVER commit .env* files with real values to git.
# .env.example is the ONLY env file that goes in source control.
#
# Env precedence (highest → lowest):
#   .env.local > .env.{environment} > .env > defaults
#
# ============================================================

# ========================
# App Identity
# ========================
APP_NAME=SYNAPSE
APP_VERSION=0.1.0

# Environment tier: development | staging | production
APP_ENV=development

# Set to false in staging/production
DEBUG=true

# debug | info | warning | error | critical
LOG_LEVEL=info

# ========================
# Security
# ========================
# Min 32 chars — use: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Comma-separated allowed origins (CORS)
# Dev:  http://localhost:5173,http://localhost:8000
# Prod: https://{{YOUR_DOMAIN}}
ALLOWED_ORIGINS=http://localhost:5173

# ========================
# Database
# ========================
# v0.1 has NO database — the vault (markdown + derived JSON graph) is file-based.
# Uncomment if/when a DB earns its place (flag the decision to the founder first).
# DATABASE_URL=postgresql://user:password@localhost:5432/synapse_dev
# DATABASE_URL=sqlite:///./synapse.db

# Connection pool (tune per environment)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ========================
# Cache / Redis
# ========================
# REDIS_URL=redis://localhost:6379/0
# REDIS_TTL_SECONDS=3600

# ========================
# Frontend / Server
# ========================
# Port your dev server listens on
PORT=8000
HOST=localhost

# Public base URL (used for absolute links, emails, etc.)
# Dev:  http://localhost:8000
# Prod: https://{{YOUR_DOMAIN}}
PUBLIC_URL=http://localhost:8000

# ========================
# AI / LLM Services — SYNAPSE's two model seams
# ========================
# Model #1 — Distill (node/subtree summarization)
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
SUMMARIZER_MODEL=claude-sonnet-5
SUMMARIZER_MAX_TOKENS=4096

# Model #2 — Render (summary → image)
OPENAI_API_KEY=sk-REPLACE-ME
IMAGE_MODEL=gpt-image-1

# Try the whole distill/render flow WITHOUT keys or cost (mock providers end-to-end)
# SYNAPSE_MOCK_MODELS=1
# Cost guard: distillations above this estimated token count ask for confirmation first
# SUMMARIZE_CONFIRM_THRESHOLD=20000

# ========================
# SYNAPSE — sources & vault
# ========================
# Comma-separated LOCAL repo paths whose markdown gets indexed.
# NOTE: this only SEEDS the initial list — after that, roots are managed in the UI
# (Menu → Sources) and persisted to data/roots.json, which takes precedence.
SYNAPSE_SOURCE_REPOS=/path/to/repo-a,/path/to/repo-b
# Where the vault (markdown + derived graph JSON) lives
SYNAPSE_VAULT_PATH=./data/vault

# ========================
# Storage
# ========================
# Local (dev)
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=./data/uploads

# S3-compatible (staging/prod)
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET={{PROJECT_NAME}}-{{environment}}
# AWS_REGION=us-east-1

# ========================
# Email / SMTP
# ========================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@{{YOUR_DOMAIN}}

# ========================
# Observability
# ========================
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=development

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ========================
# Feature Flags
# ========================
# FEATURE_FLAG_X=false
# FEATURE_FLAG_Y=false
